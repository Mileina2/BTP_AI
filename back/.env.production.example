# Déploiement web BTP IA — variables à copier dans Render (service btpia-api)
# Générez JWT_REFRESH_SECRET : voir scripts/generate-secrets.ps1

NODE_ENV=production
PORT=4000
FORCE_HTTPS=true
ASSISTANT_ENABLED=false

# Neon PostgreSQL (https://neon.tech → Connection string)
DATABASE_URL=

# Secrets JWT (min 32 caractères — NE PAS réutiliser les valeurs dev faibles)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URLs publiques (à mettre à jour après déploiement Vercel + Render)
FRONTEND_URL=https://VOTRE-SITE.vercel.app
API_PUBLIC_URL=https://VOTRE-API.onrender.com

# Brevo SMTP (2FA, reset password)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cloudinary (recommandé — uploads persistants en prod)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Premier déploiement uniquement : créer tables + compte démo
RUN_SEED=true
