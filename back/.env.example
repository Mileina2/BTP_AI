# PostgreSQL (Prisma)
DATABASE_URL="postgresql://btpia:btpia_dev@127.0.0.1:15432/btpia?schema=public"

# Legacy MongoDB (optionnel — laisser vide pour PostgreSQL uniquement)
MONGO_URI=

PORT=4000
FRONTEND_URL=http://localhost:5173

# JWT — générez une clé aléatoire d'au moins 32 caractères (openssl rand -base64 32)
JWT_SECRET=change_me_use_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
MEDIA_ACCESS_TTL=4h
JWT_REFRESH_SECRET=change_me_refresh_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d
RESET_TOKEN_EXPIRE=10m

# Production : forcer HTTPS derrière reverse proxy (Render, Railway, Nginx)
FORCE_HTTPS=false

# OpenAI (assistant IA — désactivé par défaut)
ASSISTANT_ENABLED=false
OPENAI_API_KEY=

# Cloudinary (upload photos/vidéos chantier — recommandé en production)
# Sans ces variables : fichiers stockés localement dans back/uploads/chantiers/
# Créez un compte gratuit sur https://cloudinary.com puis copiez les 3 valeurs du dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# URL publique de l'API (obligatoire pour les liens de fichiers locaux en prod)
API_PUBLIC_URL=http://localhost:4000

# CORS prod (origines supplémentaires, séparées par des virgules)
# CORS_ORIGINS=https://app.votredomaine.com

# Email SMTP — Brevo recommandé (gratuit ~300 mails/jour)
# https://www.brevo.com → SMTP & API → clé SMTP + vérifier le sender
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER = email de connexion Brevo
# SMTP_PASS = clé SMTP (pas l'API key, pas le mot de passe compte)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@votredomaine.com

# Google OAuth (connexion / inscription entrepreneur)
# Créez un projet sur https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# Authorized JavaScript origins: http://localhost:4173 et http://localhost:5173
GOOGLE_CLIENT_ID=
